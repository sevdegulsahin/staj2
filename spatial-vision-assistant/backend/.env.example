# ─── Spatial Vision Assistant — Backend Environment ───────────────────────────
# Copy this file to .env and fill in your actual values

# Vast.ai GPU endpoint  (replace with your rented instance IP + port)
VLLM_ENDPOINT=http://<VAST_AI_IP>:8000/v1/chat/completions
VLLM_MODEL=Qwen/Qwen2-VL-7B-Instruct
VLLM_TIMEOUT=60

# Whisper
WHISPER_MODEL=base       # tiny | base | small | medium | large
WHISPER_DEVICE=cuda      # cuda | cpu

# TTS
TTS_ENABLED=true
TTS_ENGINE=gtts          # gtts | pyttsx3 | coqui
